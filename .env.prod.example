# Production environment template — copy to .env.prod and fill in secrets.
# Never commit the real .env.prod file.

# Public site
NUXT_PUBLIC_SITE_URL=https://example.com
NUXT_PUBLIC_SITE_NAME=Acme Studio
NUXT_PUBLIC_ENV=production

# Backend API (server-only, never exposed to client)
NUXT_API_BASE_URL=https://api.example.com

# Cache revalidation (must match REVALIDATE_SECRET on the Fastify backend)
# Generate a strong value: `openssl rand -hex 32`
NUXT_REVALIDATE_SECRET=change-me-revalidate-secret

# Analytics — Umami
NUXT_PUBLIC_UMAMI_HOST=https://analytics.example.com
NUXT_PUBLIC_UMAMI_WEBSITE_ID=change-me-website-id
