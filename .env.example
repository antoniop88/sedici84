# === Required ===
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# App environment and @nuxtjs/robots indexability (development | staging | production)
NUXT_PUBLIC_ENV=development

# === Optional (defaults from config/site.ts) ===
NUXT_PUBLIC_SITE_NAME=Acme Studio
NUXT_PUBLIC_DEFAULT_LOCALE=it

# === Analytics — optional ===
# NUXT_PUBLIC_UMAMI_HOST=https://analytics.example.com
# NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# === Fase 9 — server-only (never expose to client) ===
# NUXT_API_BASE_URL=
# NUXT_API_KEY=
# NUXT_USE_FASTILY_MOCK=true

# --- Required in production ---
# Secret protecting POST /api/collections/revalidate. The dev default below is fine locally,
# but the server REFUSES TO BOOT in production if this is left unset or at the dev default.
# Generate a strong value: `openssl rand -hex 32`
NUXT_REVALIDATE_SECRET=dev-revalidate-secret
