{
  "name": "nuxt-starter",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "nuxt prepare && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxi typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@nuxt/content": "^3.15.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.3.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/seo": "5.3.2",
    "@resvg/resvg-js": "^2.6.2",
    "@takumi-rs/core": "2.0.0-rc.5",
    "better-sqlite3": "^12.11.1",
    "nuxt": "^4.4.8",
    "nuxt-security": "^2.6.0",
    "sharp": "^0.35.3",
    "satori": "^0.26.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "^24.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.3.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.3.6"
  },
  "lint-staged": {
    "*.{js,ts,mjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  }
}
